# Application
NODE_ENV=development
PORT=3000
CORS_ORIGIN=*

# Database
DB_PATH=data/time-off.db
DB_SYNCHRONIZE=false

# Auth
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRES_IN=24h

# HCM Integration
HCM_BASE_URL=http://localhost:4000
HCM_API_KEY=hcm-secret-key
HCM_TIMEOUT=10000
HCM_MAX_RETRIES=3
HCM_RETRY_DELAY=1000

# Webhook
WEBHOOK_HMAC_SECRET=your-hmac-secret-change-in-production
WEBHOOK_CALLBACK_URL=http://localhost:3000/api/v1/webhooks/hcm/balance-update

# Mock HCM (used by mock-hcm server to call back ReadyOn)
READYON_WEBHOOK_URL=http://localhost:3000/api/v1/webhooks/hcm/balance-update
