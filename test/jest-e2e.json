{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testMatch": ["<rootDir>/test/e2e/**/*.e2e-spec.ts"],
  "transform": { "^.+\\.(t|j)s$": ["ts-jest", { "tsconfig": "tsconfig.json" }] },
  "moduleNameMapper": { "^src/(.*)$": "<rootDir>/src/$1" },
  "testEnvironment": "node",
  "testTimeout": 30000
}
